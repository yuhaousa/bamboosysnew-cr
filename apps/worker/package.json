{
  "name": "@bamboosys/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply bamboosys-db",
    "db:migrate:local": "wrangler d1 migrations apply bamboosys-db --local",
    "db:seed": "wrangler d1 execute bamboosys-db --local --file=../../migrations/001_initial.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bamboosys/shared": "workspace:*",
    "hono": "^4.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.109.0"
  }
}
