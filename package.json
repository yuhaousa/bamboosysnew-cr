{
  "name": "bamboosys-cms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n worker,admin,frontend -c cyan,green,yellow \"pnpm dev:worker\" \"pnpm dev:admin\" \"pnpm dev:frontend\"",
    "dev:admin": "pnpm --filter admin dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:worker": "pnpm --filter worker dev",
    "build:admin": "pnpm --filter admin build",
    "build:frontend": "pnpm --filter frontend build",
    "build:all": "pnpm --filter shared build && pnpm --filter admin build && pnpm --filter frontend build",
    "deploy:worker": "pnpm --filter worker deploy",
    "db:migrate": "wrangler d1 migrations apply bamboosys-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply bamboosys-db --remote"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
